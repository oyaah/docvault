# LLM provider (via LiteLLM)
OPENAI_API_KEY=sk-your-openai-api-key-here
# Or use any LiteLLM-supported provider
# ANTHROPIC_API_KEY=sk-ant-...

# Model config
DOCVAULT_LLM_MODEL=gpt-4o-mini

# Embedding backend: "openai" (default) or "local" (requires torch)
DOCVAULT_EMBEDDING_BACKEND=openai
DOCVAULT_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DOCVAULT_EMBEDDING_DIMENSIONS=1536
# DOCVAULT_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3  # only if backend=local

# Pinecone (managed vector DB)
DOCVAULT_PINECONE_API_KEY=pcsk_your-pinecone-api-key-here
DOCVAULT_PINECONE_INDEX_NAME=docvault
DOCVAULT_PINECONE_CLOUD=aws
DOCVAULT_PINECONE_REGION=us-east-1

# Paths
DOCVAULT_DATA_DIR=./data
DOCVAULT_CORPUS_DIR=./corpus

# ONNX models (reranker + NLI verifier)
DOCVAULT_ONNX_MODELS_DIR=./models

# Retrieval tuning
DOCVAULT_FUSION_ALPHA=0.6
DOCVAULT_RERANK_TOP_K=5
DOCVAULT_CONFIDENCE_THRESHOLD=0.3

# Redis (session memory + retrieval cache)
DOCVAULT_REDIS_URL=redis://redis:6379/0

# Celery (async workers)
DOCVAULT_CELERY_BROKER_URL=redis://redis:6379/1
DOCVAULT_CELERY_RESULT_BACKEND=redis://redis:6379/1

# Server
DOCVAULT_HOST=0.0.0.0
DOCVAULT_PORT=8000

# Observability
DOCVAULT_OTEL_EXPORTER_ENDPOINT=  # empty = stdout, or set OTLP endpoint
